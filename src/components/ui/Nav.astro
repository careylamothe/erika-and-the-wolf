---
const links = [
  { href: "/", label: "Home" },
  { href: "/about", label: "About" },
  { href: "/musicians", label: "Musicians" },
  { href: "/repertoire", label: "Repertoire" },
  { href: "/concerts", label: "Concerts" },
  { href: "/media", label: "Media" },
  { href: "/contact", label: "Contact" },
];

const current = Astro.url.pathname;
---

<nav aria-label="Main navigation">
  <a href="/" class="nav-logo" aria-label="Home">
    <img
    src="/src/styles/assets/erika-and-the-wolf.svg"
    alt="Erika & the Wolf"
    width="48"
    height="37"
    class="nav-logo-img"
    />
    <span>Erika & the Wolf</span>
  </a>

  <button
    id="nav-toggle"
    aria-expanded="false"
    aria-controls="nav-menu"
    aria-label="Toggle navigation menu"
  >
    <span></span><span></span><span></span>
  </button>

  <ul id="nav-menu" role="list">
    {links.map(({ href, label }) => (
      <li>
        <a href={href} aria-current={current === href ? "page" : undefined}>
          {label}
        </a>
      </li>
    ))}
  </ul>
</nav>

<script>
  const toggle = document.getElementById("nav-toggle")!;
  const menu = document.getElementById("nav-menu")!;
  toggle.addEventListener("click", () => {
    const expanded = toggle.getAttribute("aria-expanded") === "true";
    toggle.setAttribute("aria-expanded", String(!expanded));
    menu.toggleAttribute("data-open");
  });
</script>